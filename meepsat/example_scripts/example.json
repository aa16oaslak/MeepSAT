{
  "simulation": {
    "name": "multi_arc_example",
    "parallel": "False",
    "primary_params": {
      "sim_type": "2D",
      "cell_size": {
        "x": 900,
        "y": 448,
        "z": 0
      },
      "resolution": 3,
      "smallest_freq": 0.3,
      "meep_unit_length": 1
    } 
  },

  "boundary_layers": {
    "boundary": {
      "type": "PML",
      "size": 2,
      "factor_dpml": 2
    }
  },

  "sources": {
    "source1": {
      "type": "GaussianBeam",
      "center_x": 445,
      "center_y": 0,
      "center_z": 0,
      "size_x": 0,
      "size_y": 448,
      "size_z": 0,
      "component": "Ez",
      "frequecy": 0.3,
      "extra_args": {
        "start_time": 0,
        "end_time": "mp.inf",
        "angle": 180,
        "width": 2.22,
        "beam_x0": {
          "x": 0,
          "y": 0,
          "z": 0
        },
        "beam_E0": {
          "x": 0,
          "y": 0,
          "z": 1
        }
      }
    },
    "source2": {
      "type": "ContinuousPlaneWaves",
      "center_x": -95,
      "center_y": 0,
      "center_z": 0,
      "size_x": 0,
      "size_y": 100,
      "size_z": 0,
      "component": "Ez",
      "frequecy": 0.3,
      "extra_args": {
      "angle": 0,
      "is_integrated": true,
      "start_time": 0,
      "end_time": "mp.inf"
      }
    }
  },

  "lenses": {
    "lens1": {
      "name": "plano_hyperbolic_lens",
      "n_refr": 1.57,
      "r1": 100000,
      "r2": -456,
      "c1": 100000,
      "c2": -2.4649,
      "thick": 80,
      "diameter": 448,
      "x": 80,
      "AR_left_layers": [0.25, 0.3, 0.15],
      "AR_left_materials": [1.4, 1.2, 1.3],
      "AR_right_layers": [0.2, 0.25],
      "AR_right_materials": [1.3, 1.2]
    }
  },

  "apertures": {
    "aperture1": {
      "type": "square",
      "diameter": 408.678,
      "pos_x": 130,
      "thickness": 2,
      "n_refr": 1.45,
      "conductivity": "mp.inf"
    }
  },

  "slabs": {
      "glass_slab": {
        "name": "block",
        "center": "mp.Vector3(150, 0, 0)",
        "size": "mp.Vector3(20, 300, 0)",
        "material": "mp.Medium(epsilon=1.45**2)",
        "angle": 0,
        "rot_axis": "x"
      },
      "tilted_slab": {
        "name": "block",
        "center": "mp.Vector3(250, 0, 0)",
        "size": "mp.Vector3(10, 200, 0)",
        "material": "mp.Medium(epsilon=2.1**2)",
        "angle": 15,
        "rot_axis": "z" 
      },
      "bk7_glass": {
        "name": "block",
        "center": "mp.Vector3(200, 0, 0)",
        "size": "mp.Vector3(15, 250, 0)",
        "material": "mp.Medium(epsilon=1.0, E_susceptibilities=[mp.LorentzianSusceptibility(frequency=0.0, gamma=0.0, sigma_diag=mp.Vector3(1.5168**2-1.0, 1.5168**2-1.0, 1.5168**2-1.0))])",
        "angle": 0,
        "rot_axis": "x"
      }
  },

  "monitor":{
    "monitor1":{
      "type": "mp.Volume",
      "center": [340, 0, 0],
      "size": [0.25, 300, 0],
      "data_required": {
        "at_every_timestep": 25,
        "at_end": ["Ez2_dB"]}
    } 
  },
  "run_reference_sim": true,

  "flux_monitor": {
    "incident_flux": {
      "center": "mp.Vector3(50, 0, 0)",
      "size": "mp.Vector3(0, 400, 0)",
      "direction": "mp.X",
      "monitor_type": "incident",
      "freq_min": 0.25,
      "freq_max": 0.35,
      "nfreq": 100,
      "use_flux_file": "None" 
    },
    "reflection_flux": {
      "center": "mp.Vector3(40, 0, 0)",
      "size": "mp.Vector3(0, 400, 0)",
      "direction": "mp.X",
      "monitor_type": "reflection"
    },
    "transmission_flux": {
      "center": "mp.Vector3(300, 0, 0)",
      "size": "mp.Vector3(0, 400, 0)",
      "direction": "mp.X",
      "monitor_type": "transmission"
    }
  },

  "output": {
    "flux_monitor_data_dir": "output_files/flux_data",
    "flux_monitor_save_freq": 5,
    "savepath": {
      "path": "output_files/"
    },
    "animation_options": {
      "get_mp4": true,
      "image_every": 5,
      "Nfps": 15,
      "movie_name": "multi_arc_example_animation",
      "use_streaming_mp4": true
    },
    "epsilon_h5_file": {
      "filename": "multi_arc_example_"
    },
    "runtime": {
      "command": "until= 1000"
    },      
    "data_required": {
      "at_every_timestep": 5,
      "at_every": ["animate_Ez2_dB", "Ez2_dB"],
      "at_end": ["output_efield_z"]
    }
  }
}